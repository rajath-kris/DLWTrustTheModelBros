{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinel-ai.local/schemas/capture-request.schema.json",
  "title": "CaptureRequest",
  "type": "object",
  "required": [
    "capture_id",
    "timestamp_utc",
    "platform",
    "app_name",
    "window_title",
    "monitor",
    "region",
    "image_base64"
  ],
  "properties": {
    "capture_id": { "type": "string" },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "platform": { "type": "string", "enum": ["windows", "macos"] },
    "app_name": { "type": "string" },
    "window_title": { "type": "string" },
    "monitor": {
      "type": "object",
      "required": ["left", "top", "width", "height", "scale"],
      "properties": {
        "left": { "type": "integer" },
        "top": { "type": "integer" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "scale": { "type": "number", "minimum": 0.5 }
      }
    },
    "region": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "image_base64": { "type": "string", "minLength": 1 }
  }
}
