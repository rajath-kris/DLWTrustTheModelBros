{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinel-ai.local/schemas/learning-state.schema.json",
  "title": "LearningState",
  "type": "object",
  "required": ["schema_version", "updated_at", "captures", "gaps", "topics", "question_bank", "quizzes", "readiness_axes"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "updated_at": { "type": "string", "format": "date-time" },
    "captures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capture_id", "timestamp_utc", "app_name", "window_title", "socratic_prompt", "gaps"],
        "properties": {
          "capture_id": { "type": "string" },
          "timestamp_utc": { "type": "string", "format": "date-time" },
          "app_name": { "type": "string" },
          "window_title": { "type": "string" },
          "socratic_prompt": { "type": "string" },
          "gaps": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gap_id", "concept", "severity", "confidence", "status", "capture_id", "evidence_url", "priority_score"],
        "properties": {
          "gap_id": { "type": "string" },
          "concept": { "type": "string" },
          "severity": { "type": "number", "minimum": 0, "maximum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "status": { "type": "string", "enum": ["open", "reviewing", "closed"] },
          "capture_id": { "type": "string" },
          "evidence_url": { "type": "string" },
          "priority_score": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic_id", "name", "mastery_score"],
        "properties": {
          "topic_id": { "type": "string" },
          "name": { "type": "string" },
          "mastery_score": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "question_bank": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "topic", "type", "question_text", "options", "correct_answer", "source", "source_type", "captured_from_sentinel", "concept"],
        "properties": {
          "id": { "type": "string" },
          "topic": { "type": "string" },
          "type": { "type": "string", "enum": ["MCQ"] },
          "question_text": { "type": "string" },
          "options": { "type": "array", "minItems": 2, "items": { "type": "string" } },
          "correct_answer": { "type": "string" },
          "source": { "type": "string" },
          "source_type": { "type": "string", "enum": ["pyq", "tutorial", "sentinel"] },
          "captured_from_sentinel": { "type": "boolean" },
          "concept": { "type": "string" }
        }
      }
    },
    "quizzes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "topic", "date_taken", "sources", "score", "questions", "mastery_delta", "generated_gap_ids"],
        "properties": {
          "id": { "type": "string" },
          "topic": { "type": "string" },
          "date_taken": { "type": "string", "format": "date-time" },
          "sources": { "type": "array", "items": { "type": "string", "enum": ["pyq", "tutorial", "sentinel"] } },
          "score": {
            "type": "object",
            "required": ["correct", "total"],
            "properties": {
              "correct": { "type": "integer", "minimum": 0 },
              "total": { "type": "integer", "minimum": 1 }
            }
          },
          "questions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["question_id", "question_text", "options", "correct_answer", "user_answer", "is_correct", "source", "concept"],
              "properties": {
                "question_id": { "type": "string" },
                "question_text": { "type": "string" },
                "options": { "type": "array", "minItems": 2, "items": { "type": "string" } },
                "correct_answer": { "type": "string" },
                "user_answer": { "type": "string" },
                "is_correct": { "type": "boolean" },
                "source": { "type": "string" },
                "concept": { "type": "string" }
              }
            }
          },
          "mastery_delta": { "type": "number" },
          "generated_gap_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "readiness_axes": {
      "type": "object",
      "required": ["concept_mastery", "deadline_pressure", "retention_risk", "problem_transfer", "consistency"],
      "properties": {
        "concept_mastery": { "type": "number", "minimum": 0, "maximum": 1 },
        "deadline_pressure": { "type": "number", "minimum": 0, "maximum": 1 },
        "retention_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "problem_transfer": { "type": "number", "minimum": 0, "maximum": 1 },
        "consistency": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
