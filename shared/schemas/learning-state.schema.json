{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinel-ai.local/schemas/learning-state.schema.json",
  "title": "LearningState",
  "type": "object",
  "required": ["updated_at", "captures", "gaps", "readiness_axes"],
  "properties": {
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "captures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capture_id", "timestamp_utc", "app_name", "window_title", "socratic_prompt", "gaps"],
        "properties": {
          "capture_id": { "type": "string" },
          "timestamp_utc": { "type": "string", "format": "date-time" },
          "app_name": { "type": "string" },
          "window_title": { "type": "string" },
          "socratic_prompt": { "type": "string" },
          "gaps": { "type": "array", "items": { "type": "string" } },
          "course_id": { "type": "string", "default": "all" },
          "module_id": { "type": ["string", "null"] },
          "material_id": { "type": ["string", "null"] },
          "source_warning": { "type": ["string", "null"] },
          "source_context": {
            "type": ["object", "null"],
            "required": ["module_id", "module_name", "match_score", "matched"],
            "properties": {
              "module_id": { "type": "string" },
              "module_name": { "type": "string" },
              "material_id": { "type": ["string", "null"] },
              "material_name": { "type": ["string", "null"] },
              "match_score": { "type": "number", "minimum": 0, "maximum": 1 },
              "matched": { "type": "boolean" }
            }
          }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gap_id", "concept", "severity", "confidence", "status", "capture_id", "evidence_url", "priority_score"],
        "properties": {
          "gap_id": { "type": "string" },
          "concept": { "type": "string" },
          "severity": { "type": "number", "minimum": 0, "maximum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "basis_question": { "type": ["string", "null"] },
          "basis_answer_excerpt": { "type": ["string", "null"] },
          "gap_type": { "type": ["string", "null"], "enum": ["concept", "reasoning", "misconception", null] },
          "course_id": { "type": "string", "default": "all" },
          "module_id": { "type": ["string", "null"] },
          "material_id": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["open", "reviewing", "closed"] },
          "capture_id": { "type": "string" },
          "evidence_url": { "type": "string" },
          "deadline_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "priority_score": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "courses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["course_id", "course_name"],
        "properties": {
          "course_id": { "type": "string" },
          "course_name": { "type": "string" }
        }
      },
      "default": []
    },
    "topic_mastery": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic_id", "course_id", "name", "current", "target", "open_gaps"],
        "properties": {
          "topic_id": { "type": "string" },
          "course_id": { "type": "string" },
          "name": { "type": "string" },
          "current": { "type": "number", "minimum": 0, "maximum": 1 },
          "target": { "type": "number", "minimum": 0, "maximum": 1 },
          "open_gaps": { "type": "integer", "minimum": 0 }
        }
      },
      "default": []
    },
    "study_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "course_id", "topic_id", "title", "rationale", "eta_minutes", "priority", "source_gap_ids"],
        "properties": {
          "action_id": { "type": "string" },
          "course_id": { "type": "string" },
          "topic_id": { "type": "string" },
          "title": { "type": "string" },
          "rationale": { "type": "string" },
          "eta_minutes": { "type": "integer", "minimum": 5, "maximum": 240 },
          "priority": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_gap_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "default": []
    },
    "deadlines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["deadline_id", "course_id", "name", "due_date", "readiness_score", "associated_gap_ids"],
        "properties": {
          "deadline_id": { "type": "string" },
          "course_id": { "type": "string" },
          "name": { "type": "string" },
          "due_date": { "type": "string", "format": "date-time" },
          "readiness_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "associated_gap_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "default": []
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["doc_id", "course_id", "module_id", "name", "size_bytes", "type", "uploaded_at", "file_url", "is_anchor"],
        "properties": {
          "doc_id": { "type": "string" },
          "course_id": { "type": "string" },
          "module_id": { "type": "string" },
          "name": { "type": "string" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "type": { "type": "string" },
          "uploaded_at": { "type": "string", "format": "date-time" },
          "file_url": { "type": "string" },
          "is_anchor": { "type": "boolean" }
        }
      },
      "default": []
    },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["session_id", "course_id", "thread_id", "turn_index", "timestamp_utc", "summary", "topic", "gap_ids"],
        "properties": {
          "session_id": { "type": "string" },
          "course_id": { "type": "string" },
          "thread_id": { "type": "string" },
          "turn_index": { "type": "integer", "minimum": 0 },
          "timestamp_utc": { "type": "string", "format": "date-time" },
          "summary": { "type": "string" },
          "topic": { "type": "string" },
          "gap_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "capture_id": { "type": ["string", "null"] }
        }
      },
      "default": []
    },
    "question_bank": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question_id", "topic", "source", "concept", "question", "options", "correct_answer", "course_id"],
        "properties": {
          "question_id": { "type": "string" },
          "topic": { "type": "string" },
          "source": { "type": "string", "enum": ["pyq", "tutorial", "sentinel"] },
          "concept": { "type": "string" },
          "question": { "type": "string" },
          "options": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" }
          },
          "correct_answer": { "type": "string" },
          "explanation": { "type": ["string", "null"] },
          "course_id": { "type": "string" },
          "module_id": { "type": ["string", "null"] }
        }
      },
      "default": []
    },
    "quizzes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "quiz_id",
          "timestamp_utc",
          "topic",
          "sources",
          "total_questions",
          "correct_answers",
          "score",
          "results",
          "course_id"
        ],
        "properties": {
          "quiz_id": { "type": "string" },
          "timestamp_utc": { "type": "string", "format": "date-time" },
          "topic": { "type": "string" },
          "sources": {
            "type": "array",
            "items": { "type": "string", "enum": ["pyq", "tutorial", "sentinel"] }
          },
          "total_questions": { "type": "integer", "minimum": 0 },
          "correct_answers": { "type": "integer", "minimum": 0 },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["question_id", "topic", "source", "concept", "user_answer", "correct_answer", "is_correct"],
              "properties": {
                "question_id": { "type": "string" },
                "topic": { "type": "string" },
                "source": { "type": "string", "enum": ["pyq", "tutorial", "sentinel"] },
                "concept": { "type": "string" },
                "user_answer": { "type": "string" },
                "correct_answer": { "type": "string" },
                "is_correct": { "type": "boolean" }
              }
            }
          },
          "course_id": { "type": "string" },
          "module_id": { "type": ["string", "null"] }
        }
      },
      "default": []
    },
    "readiness_axes": {
      "type": "object",
      "required": ["concept_mastery", "deadline_pressure", "retention_risk", "problem_transfer", "consistency"],
      "properties": {
        "concept_mastery": { "type": "number", "minimum": 0, "maximum": 1 },
        "deadline_pressure": { "type": "number", "minimum": 0, "maximum": 1 },
        "retention_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "problem_transfer": { "type": "number", "minimum": 0, "maximum": 1 },
        "consistency": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
