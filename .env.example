# Environment
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Service wiring
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8000
BRIDGE_MATERIAL_UPLOAD_MAX_BYTES=15728640
SENTINEL_RUNTIME_ENABLED=1
SENTINEL_RUNTIME_PYTHON=
SENTINEL_RUNTIME_WORKDIR=
SENTINEL_RUNTIME_STOP_TIMEOUT_SECONDS=2.0
# Comma separated values supported.
DASHBOARD_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
SENTINEL_BRIDGE_URL=http://127.0.0.1:8000
SENTINEL_ACTIVE_MODULE_ID=
SENTINEL_OVERLAY_PROMPT_TTL_MS=20000
SENTINEL_OVERLAY_LOADING_DOT_INTERVAL_MS=350
SENTINEL_OVERLAY_MIN_WIDTH=320
SENTINEL_OVERLAY_MAX_WIDTH=520
SENTINEL_OVERLAY_INPUT_MAX_CHARS=280
SENTINEL_OVERLAY_SHOW_INPUT_CONFIRMATION=1
SENTINEL_OVERLAY_INPUT_REQUIRED=1
SENTINEL_OVERLAY_THINKING_HOLD_MS=2000
SENTINEL_OVERLAY_THINKING_MIN_WIDTH=220
SENTINEL_OVERLAY_THINKING_MAX_WIDTH=280
SENTINEL_UI_FADE_IN_MS=220
SENTINEL_UI_FADE_TEXT_STAGGER_MS=60
SENTINEL_UI_USE_ACTOR_FONT=1
SENTINEL_TEST_MODE=0
SENTINEL_LOCAL_TRIGGER_ENABLED=0
SENTINEL_LOCAL_TRIGGER_KEY=Ctrl+Shift+S
SENTINEL_TEST_SCENARIO_LABEL=
VITE_API_BASE_URL=http://127.0.0.1:8000
